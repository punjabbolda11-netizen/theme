{%- comment -%} Punjab Bolda · Featured Products — luxury grid {%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign col = s.collection
-%}
<section class="pb pb-section pb-fp" style="background:{{ s.bg }};">
  <div class="pb-wrap">
    <header class="pb-fp__head pb-reveal">
      {%- if s.eyebrow != blank -%}<p class="pb-eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="pb-h2">{{ s.heading }}</h2>{%- endif -%}
    </header>

    <div class="pb-fp__grid">
      {%- if s.collection != blank and col.products.size > 0 -%}
        {%- for product in col.products limit: s.count -%}
          {% render 'pb-product-card', product: product, quick_add: s.quick_add %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..s.count) -%}
          <article class="pb-card pb-reveal"><div class="pb-card__media pb-media">{{ 'product-2' | placeholder_svg_tag: 'pb-card__ph' }}</div>
          <div class="pb-card__body"><h3 class="pb-card__title">Product title</h3><p class="pb-card__price">$0.00</p></div></article>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if s.btn_label != blank -%}
      <div class="pb-fp__foot pb-reveal"><a class="pb-btn pb-btn--ghost" href="{{ s.btn_link | default: col.url | default: '#' }}">{{ s.btn_label }}</a></div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.pb-fp__head{margin-bottom:clamp(1.8rem,4vw,2.8rem);}
.pb-fp__grid{display:grid;grid-template-columns:repeat(2,1fr);gap:clamp(1rem,2.5vw,2rem) clamp(.8rem,2vw,1.4rem);}
.pb-fp__foot{margin-top:clamp(2.2rem,4vw,3rem);display:flex;justify-content:center;}
@media(min-width:750px){.pb-fp__grid{grid-template-columns:repeat(3,1fr);}}
@media(min-width:990px){.pb-fp__grid{grid-template-columns:repeat(4,1fr);}}
{% endstylesheet %}

{% schema %}
{
  "name": "PB · Featured Products",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FRESH DROPS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "New this season." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "count", "min": 2, "max": 12, "step": 1, "label": "Products to show", "default": 8 },
    { "type": "checkbox", "id": "quick_add", "label": "Enable quick add to cart", "default": true },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Shop all" },
    { "type": "url", "id": "btn_link", "label": "Button link" },
    { "type": "color", "id": "bg", "label": "Background", "default": "#F5F1E8" }
  ],
  "presets": [ { "name": "PB · Featured Products" } ]
}
{% endschema %}
