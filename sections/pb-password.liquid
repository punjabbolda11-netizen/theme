{%- comment -%}
  Punjab Bolda · Password (coming soon) page.
  Self-contained: defines its own tokens + styles so it renders correctly inside
  layout/password.liquid even without pb-base.css. Uses native storefront password
  + native customer signup forms.
{%- endcomment -%}
{%- liquid assign s = section.settings -%}
<section class="pbp" style="
  --pbp-bg:{{ s.bg }};--pbp-fg:{{ s.fg }};--pbp-gold:{{ s.accent }};
  {% if s.image != blank %}--pbp-img:url('{{ s.image | image_url: width: 2400 }}');--pbp-overlay:{{ s.overlay | divided_by: 100.0 }};{% endif %}">
  {%- if s.image != blank -%}<span class="pbp__bg" aria-hidden="true"></span><span class="pbp__scrim" aria-hidden="true"></span>{%- endif -%}

  <div class="pbp__inner">
    <div class="pbp__brand">
      {%- if s.logo != blank -%}
        <img class="pbp__logo" src="{{ s.logo | image_url: width: 480 }}" width="200" alt="{{ shop.name | escape }}">
      {%- else -%}
        <span class="pbp__wordmark">{{ s.brand | default: shop.name }}</span>
      {%- endif -%}
    </div>

    {%- if s.eyebrow != blank -%}<p class="pbp__eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
    <h1 class="pbp__title">{{ s.heading | default: 'Something is coming.' }}</h1>
    {%- if s.text != blank -%}<p class="pbp__text">{{ s.text }}</p>{%- endif -%}

    {%- comment -%} Newsletter signup (native customer form) {%- endcomment -%}
    {%- if s.show_signup -%}
      {%- form 'customer', class: 'pbp__form' -%}
        <input type="hidden" name="contact[tags]" value="prelaunch">
        {%- if form.posted_successfully? -%}
          <p class="pbp__success">{{ s.success | default: 'You’re on the list. We’ll be in touch.' }}</p>
        {%- else -%}
          <label class="pbp__sr" for="pbp-email">Email</label>
          <div class="pbp__row">
            <input id="pbp-email" type="email" name="contact[email]" required autocomplete="email" placeholder="{{ s.placeholder | default: 'Enter your email' }}">
            <button type="submit">{{ s.btn_label | default: 'Notify me' }}</button>
          </div>
          {%- if form.errors -%}<p class="pbp__error">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>{%- endif -%}
        {%- endif -%}
      {%- endform -%}
    {%- endif -%}

    {%- if s.show_social and s.instagram != blank -%}
      <div class="pbp__social"><a href="{{ s.instagram }}" target="_blank" rel="noopener">Instagram</a>{% if s.tiktok != blank %}<a href="{{ s.tiktok }}" target="_blank" rel="noopener">TikTok</a>{% endif %}</div>
    {%- endif -%}

    {%- comment -%} Native storefront password entry {%- endcomment -%}
    <details class="pbp__enter">
      <summary>{{ s.enter_label | default: 'Enter using password' }}</summary>
      {%- form 'storefront_password', class: 'pbp__pwform' -%}
        {%- if form.errors -%}<p class="pbp__error">{{ form.errors.messages.form }}</p>{%- endif -%}
        <div class="pbp__row">
          <input type="password" name="password" autocomplete="current-password" placeholder="Store password" aria-label="Store password" required>
          <button type="submit">Enter</button>
        </div>
      {%- endform -%}
    </details>
  </div>

  <p class="pbp__credit">{{ powered_by_link }}</p>
</section>

{% stylesheet %}
.pbp{--pbp-font-h:"Playfair Display",Georgia,serif;--pbp-font-b:-apple-system,BlinkMacSystemFont,"Segoe UI",Inter,Helvetica,Arial,sans-serif;
  position:relative;min-height:100svh;display:flex;flex-direction:column;align-items:center;justify-content:center;
  text-align:center;padding:2.5rem 1.5rem;background:var(--pbp-bg,#111);color:var(--pbp-fg,#F5F1E8);font-family:var(--pbp-font-b);overflow:hidden;isolation:isolate;}
.pbp__bg{position:absolute;inset:0;z-index:-2;background-image:var(--pbp-img);background-size:cover;background-position:center;}
.pbp__scrim{position:absolute;inset:0;z-index:-1;background:rgba(0,0,0,var(--pbp-overlay,.55));}
.pbp__inner{max-width:540px;width:100%;}
.pbp__brand{margin-bottom:2rem;}
.pbp__logo{max-width:200px;height:auto;}
.pbp__wordmark{font-family:var(--pbp-font-h);font-size:clamp(1.6rem,5vw,2.4rem);font-weight:700;letter-spacing:.04em;text-transform:uppercase;}
.pbp__eyebrow{font-size:.7rem;letter-spacing:.28em;text-transform:uppercase;font-weight:600;color:var(--pbp-gold,#D4AF37);margin:0 0 1rem;}
.pbp__title{font-family:var(--pbp-font-h);font-size:clamp(2rem,7vw,3.6rem);line-height:1.02;font-weight:600;margin:0;letter-spacing:-.02em;text-wrap:balance;}
.pbp__text{font-size:1.02rem;line-height:1.6;opacity:.85;margin:1.1rem auto 0;max-width:42ch;}
.pbp__form{margin-top:2rem;}
.pbp__sr{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);}
.pbp__row{display:flex;gap:.5rem;max-width:420px;margin-inline:auto;}
.pbp__row input{flex:1;min-height:52px;padding:0 1.1rem;border:1px solid rgba(255,255,255,.25);background:rgba(255,255,255,.06);color:inherit;border-radius:4px;font-size:1rem;min-width:0;}
.pbp__row input::placeholder{color:currentColor;opacity:.55;}
.pbp__row button{min-height:52px;padding:0 1.4rem;border:0;border-radius:4px;background:var(--pbp-gold,#D4AF37);color:#1a1407;font-weight:600;font-size:.8rem;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;white-space:nowrap;transition:transform .3s ease;}
.pbp__row button:hover{transform:translateY(-2px);}
.pbp__success{color:var(--pbp-gold,#D4AF37);font-weight:600;font-size:1.05rem;margin-top:2rem;}
.pbp__error{color:#e8b4b4;font-size:.84rem;margin-top:.7rem;}
.pbp__social{display:flex;gap:1.4rem;justify-content:center;margin-top:2rem;}
.pbp__social a{color:inherit;text-decoration:none;font-size:.74rem;letter-spacing:.14em;text-transform:uppercase;opacity:.8;border-bottom:1px solid transparent;padding-bottom:2px;}
.pbp__social a:hover{opacity:1;border-color:var(--pbp-gold);}
.pbp__enter{margin-top:2.5rem;}
.pbp__enter summary{cursor:pointer;font-size:.74rem;letter-spacing:.14em;text-transform:uppercase;opacity:.7;list-style:none;}
.pbp__enter summary::-webkit-details-marker{display:none;}
.pbp__enter[open] summary{margin-bottom:1rem;}
.pbp__pwform{max-width:420px;margin-inline:auto;}
.pbp__credit{margin-top:2.5rem;font-size:.7rem;opacity:.5;}
.pbp__credit a{color:inherit;}
{% endstylesheet %}

{% schema %}
{
  "name": "PB · Password",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "text", "id": "brand", "label": "Brand text (if no logo)", "default": "PUNJAB BOLDA" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "ROOTED IN CULTURE · DRIVEN BY PRIDE" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Something is coming." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "We’re putting the finishing touches on the drop. Join the movement to be first in line." },
    { "type": "header", "content": "Email signup" },
    { "type": "checkbox", "id": "show_signup", "label": "Show email signup", "default": true },
    { "type": "text", "id": "placeholder", "label": "Placeholder", "default": "Enter your email" },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Notify me" },
    { "type": "text", "id": "success", "label": "Success message", "default": "You’re on the list. We’ll be in touch." },
    { "type": "header", "content": "Social" },
    { "type": "checkbox", "id": "show_social", "label": "Show social", "default": true },
    { "type": "url", "id": "instagram", "label": "Instagram" },
    { "type": "url", "id": "tiktok", "label": "TikTok" },
    { "type": "header", "content": "Password entry" },
    { "type": "text", "id": "enter_label", "label": "Enter label", "default": "Enter using password" },
    { "type": "header", "content": "Appearance" },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "range", "id": "overlay", "min": 0, "max": 80, "step": 5, "unit": "%", "label": "Image darkening", "default": 55 },
    { "type": "color", "id": "bg", "label": "Background", "default": "#111111" },
    { "type": "color", "id": "fg", "label": "Text", "default": "#F5F1E8" },
    { "type": "color", "id": "accent", "label": "Accent", "default": "#D4AF37" }
  ]
}
{% endschema %}
