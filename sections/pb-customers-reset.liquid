{%- comment -%} Punjab Bolda · Reset Password — native reset_customer_password {%- endcomment -%}
{%- liquid assign s = section.settings -%}
<section class="pb pb-auth" style="background:{{ s.bg }};">
  <div class="pb-wrap" style="display:grid;place-items:center;">
    <div class="pb-auth__card">
      <div class="pb-auth__head">
        <h1 class="pb-auth__title">{{ s.heading | default: 'Set a new password' }}</h1>
        <p class="pb-auth__sub">{{ s.subheading | default: 'Choose a new password for your account.' }}</p>
      </div>
      {%- form 'reset_customer_password' -%}
        {%- if form.errors -%}<div class="pb-auth__errors" role="alert">{{ form.errors | default_errors }}</div>{%- endif -%}
        <div class="pb-field"><label for="pb-reset-pass">New password</label><input type="password" id="pb-reset-pass" name="customer[password]" autocomplete="new-password" required></div>
        <div class="pb-field"><label for="pb-reset-confirm">Confirm password</label><input type="password" id="pb-reset-confirm" name="customer[password_confirmation]" autocomplete="new-password" required></div>
        <button type="submit" class="pb-btn pb-auth__btn">{{ s.btn_label | default: 'Reset password' }}</button>
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PB · Reset Password",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Set a new password" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Choose a new password for your account." },
    { "type": "text", "id": "btn_label", "label": "Button", "default": "Reset password" },
    { "type": "color", "id": "bg", "label": "Background", "default": "#EEE1D3" }
  ],
  "presets": [ { "name": "PB · Reset Password" } ]
}
{% endschema %}
