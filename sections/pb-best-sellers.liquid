{%- comment -%} Punjab Bolda · Best Sellers — snap-scroll carousel + quick add {%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign col = s.collection
  assign products = col.products
  assign limit = s.count
-%}
<section class="pb pb-section pb-bs" style="background:{{ s.bg }};">
  <div class="pb-wrap">
    <header class="pb-bs__head pb-reveal">
      <div>
        {%- if s.eyebrow != blank -%}<p class="pb-eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="pb-h2">{{ s.heading }}</h2>{%- endif -%}
      </div>
      <div class="pb-bs__nav">
        <button type="button" class="pb-bs__arrow" data-pb-prev aria-label="Previous products">{% render 'pb-icon', icon: 'arrow-left' %}</button>
        <button type="button" class="pb-bs__arrow" data-pb-next aria-label="Next products">{% render 'pb-icon', icon: 'arrow-right' %}</button>
      </div>
    </header>

    <div class="pb-bs__track" data-pb-track role="list">
      {%- if products.size > 0 -%}
        {%- for product in products limit: limit -%}
          <div class="pb-bs__cell" role="listitem">
            {% render 'pb-product-card', product: product, quick_add: s.quick_add %}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="pb-bs__cell" role="listitem">
            <article class="pb-card"><div class="pb-card__media pb-media">{{ 'product-1' | placeholder_svg_tag: 'pb-card__ph' }}</div>
            <div class="pb-card__body"><h3 class="pb-card__title">Product title</h3><p class="pb-card__price">$0.00</p></div></article>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if s.view_all_link != blank -%}
      <div class="pb-bs__foot pb-reveal"><a class="pb-btn pb-btn--ghost" href="{{ s.view_all_link }}">{{ s.view_all_label | default: 'View all' }}</a></div>
    {%- endif -%}
  </div>
</section>

<script>
(function(){
  var sec=document.currentScript.previousElementSibling;
  var track=sec.querySelector('[data-pb-track]');
  if(!track)return;
  var prev=sec.querySelector('[data-pb-prev]'),next=sec.querySelector('[data-pb-next]');
  function step(){var c=track.querySelector('.pb-bs__cell');return c?c.getBoundingClientRect().width+24:320;}
  next&&next.addEventListener('click',function(){track.scrollBy({left:step(),behavior:'smooth'});});
  prev&&prev.addEventListener('click',function(){track.scrollBy({left:-step(),behavior:'smooth'});});
})();
</script>

{% stylesheet %}
.pb-bs__head{display:flex;align-items:flex-end;justify-content:space-between;gap:1rem;margin-bottom:clamp(1.5rem,4vw,2.5rem);}
.pb-bs__nav{display:none;gap:.6rem;}
.pb-bs__arrow{width:48px;height:48px;display:grid;place-items:center;border:1px solid var(--pb-line-strong);background:transparent;border-radius:50%;color:var(--pb-text);cursor:pointer;transition:background .3s var(--pb-ease),color .3s var(--pb-ease);}
.pb-bs__arrow:hover{background:var(--pb-text);color:#fff;}
.pb-bs__track{display:grid;grid-auto-flow:column;grid-auto-columns:78%;gap:24px;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none;padding-bottom:.5rem;margin-inline:calc(var(--pb-pad-x)*-1);padding-inline:var(--pb-pad-x);}
.pb-bs__track::-webkit-scrollbar{display:none;}
.pb-bs__cell{scroll-snap-align:start;}
.pb-bs__foot{margin-top:2.5rem;display:flex;justify-content:center;}
@media(min-width:600px){.pb-bs__track{grid-auto-columns:42%;}}
@media(min-width:750px){.pb-bs__nav{display:flex;}.pb-bs__track{grid-auto-columns:31%;margin-inline:0;padding-inline:0;}}
@media(min-width:990px){.pb-bs__track{grid-auto-columns:23.5%;}}
{% endstylesheet %}

{% schema %}
{
  "name": "PB · Best Sellers",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "MOST WANTED" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best sellers" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "count", "min": 4, "max": 16, "step": 1, "label": "Products to show", "default": 8 },
    { "type": "checkbox", "id": "quick_add", "label": "Enable quick add to cart", "default": true },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "Shop all best sellers" },
    { "type": "url", "id": "view_all_link", "label": "View all link" },
    { "type": "color", "id": "bg", "label": "Background", "default": "#EEE1D3" }
  ],
  "presets": [ { "name": "PB · Best Sellers" } ]
}
{% endschema %}
