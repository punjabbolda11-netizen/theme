{%- comment -%} Punjab Bolda · Featured Collections — editorial card grid {%- endcomment -%}
{%- liquid assign s = section.settings -%}
<section class="pb pb-section pb-fcol" style="background:{{ s.bg }};">
  <div class="pb-wrap">
    {%- if s.eyebrow != blank or s.heading != blank -%}
      <header class="pb-fcol__head pb-reveal">
        {%- if s.eyebrow != blank -%}<p class="pb-eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="pb-h2">{{ s.heading }}</h2>{%- endif -%}
        {%- if s.intro != blank -%}<p class="pb-lead pb-mt-1">{{ s.intro }}</p>{%- endif -%}
      </header>
    {%- endif -%}

    <div class="pb-fcol__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign col = block.settings.collection
          assign img = block.settings.image
          if img == blank and col != blank
            assign img = col.featured_image
          endif
          assign url = block.settings.link
          if url == blank and col != blank
            assign url = col.url
          endif
        -%}
        <a class="pb-fcol__card pb-media pb-zoom pb-reveal {% if block.settings.large %}is-large{% endif %}"
           href="{{ url | default: '#' }}" {{ block.shopify_attributes }} data-pb-stagger>
          {%- liquid
            assign img_mobile = block.settings.image_mobile
            if img_mobile == blank
              assign img_mobile = img
            endif
          -%}
          {%- if img != blank -%}
            <picture>
              <source media="(min-width:750px)" srcset="{{ img | image_url: width: 800 }} 800w, {{ img | image_url: width: 1200 }} 1200w">
              <img src="{{ img_mobile | image_url: width: 800 }}"
                   srcset="{{ img_mobile | image_url: width: 500 }} 500w, {{ img_mobile | image_url: width: 800 }} 800w"
                   sizes="(min-width:750px) 46vw, 92vw" width="{{ img.width }}" height="{{ img.height }}"
                   alt="{{ block.settings.title | escape | default: col.title | escape }}" loading="lazy">
            </picture>
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'pb-fcol__ph' }}
          {%- endif -%}
          <span class="pb-fcol__overlay"></span>
          <span class="pb-fcol__caption">
            {%- if block.settings.kicker != blank -%}<span class="pb-fcol__kicker">{{ block.settings.kicker }}</span>{%- endif -%}
            <span class="pb-fcol__title">{{ block.settings.title | default: col.title }}</span>
            <span class="pb-fcol__cta">{{ block.settings.cta | default: 'Explore' }} {% render 'pb-icon', icon: 'arrow' %}</span>
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
.pb-fcol__head{max-width:640px;margin-bottom:clamp(2rem,5vw,3.5rem);}
.pb-fcol__grid{display:grid;grid-template-columns:1fr;gap:clamp(1rem,2vw,1.5rem);}
.pb-fcol__card{position:relative;display:block;aspect-ratio:3/4;border-radius:var(--pb-radius-lg);color:#fff;text-decoration:none;}
.pb-fcol__card img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}
.pb-fcol__overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,0) 35%,rgba(0,0,0,.62) 100%);}
.pb-fcol__caption{position:absolute;left:0;bottom:0;width:100%;padding:clamp(1.25rem,3vw,2rem);display:flex;flex-direction:column;gap:.4rem;z-index:2;}
.pb-fcol__kicker{font-size:.66rem;letter-spacing:.2em;text-transform:uppercase;font-weight:600;color:var(--pb-gold);}
.pb-fcol__title{font-family:var(--pb-font-heading);font-size:clamp(1.5rem,3vw,2.1rem);font-weight:600;line-height:1.05;}
.pb-fcol__cta{display:inline-flex;align-items:center;gap:.5rem;font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;font-weight:600;opacity:.85;transition:gap .35s var(--pb-ease);}
.pb-fcol__card:hover .pb-fcol__cta{gap:.9rem;}
.pb-fcol__ph{position:absolute;inset:0;width:100%;height:100%;}
@media(min-width:750px){
  .pb-fcol__grid{grid-template-columns:repeat(2,1fr);}
  .pb-fcol__card.is-large{grid-column:span 2;aspect-ratio:16/9;}
}
@media(min-width:990px){
  .pb-fcol__grid{grid-template-columns:repeat(3,1fr);}
  .pb-fcol__card.is-large{grid-column:span 2;aspect-ratio:auto;}
}
{% endstylesheet %}

{% schema %}
{
  "name": "PB · Featured Collections",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "THE COLLECTIONS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Worn with pride." },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Every drop is a chapter of Punjabi identity — designed for the streets, rooted in heritage." },
    { "type": "color", "id": "bg", "label": "Background", "default": "#F5F1E8" }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection card",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
       { "type": "image_picker", "id": "image", "label": "Custom image (overrides collection image) — desktop" },
        { "type": "image_picker", "id": "image_mobile", "label": "Custom image — mobile (optional, falls back to desktop)" },
        { "type": "text", "id": "kicker", "label": "Kicker" },
        { "type": "text", "id": "title", "label": "Title (overrides collection name)" },
        { "type": "text", "id": "cta", "label": "CTA label", "default": "Explore" },
        { "type": "url", "id": "link", "label": "Custom link (optional)" },
        { "type": "checkbox", "id": "large", "label": "Feature large (2 columns)", "default": false }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "PB · Featured Collections",
      "blocks": [
        { "type": "collection", "settings": { "kicker": "Flagship", "title": "Main Hoon Punjab", "large": true } },
        { "type": "collection", "settings": { "kicker": "Everyday", "title": "Streetwear" } },
        { "type": "collection", "settings": { "kicker": "Districts", "title": "Jila Collection" } },
        { "type": "collection", "settings": { "kicker": "Heritage", "title": "Timeless Punjab Polo" } },
        { "type": "collection", "settings": { "kicker": "Headwear", "title": "Caps" } }
      ]
    }
  ]
}
{% endschema %}
