{%- comment -%} Punjab Bolda · Brand Story — split editorial {%- endcomment -%}
{%- liquid assign s = section.settings -%}
<section class="pb pb-section pb-story {% if s.reverse %}is-reverse{% endif %}" style="background:{{ s.bg }};">
  <div class="pb-wrap pb-story__grid">
    <div class="pb-story__media pb-media pb-zoom pb-reveal">
      {%- if s.image != blank -%}
        <img src="{{ s.image | image_url: width: 900 }}"
             srcset="{{ s.image | image_url: width: 600 }} 600w, {{ s.image | image_url: width: 900 }} 900w, {{ s.image | image_url: width: 1300 }} 1300w"
             sizes="(min-width:750px) 48vw, 92vw" width="{{ s.image.width }}" height="{{ s.image.height }}"
             alt="{{ s.image.alt | escape | default: 'Punjab Bolda' }}" loading="lazy">
      {%- else -%}{{ 'lifestyle-2' | placeholder_svg_tag: 'pb-story__ph' }}{%- endif -%}
    </div>

    <div class="pb-story__body pb-reveal" style="--pb-delay:120ms">
      {%- if s.eyebrow != blank -%}<p class="pb-eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="pb-h2">{{ s.heading }}</h2>{%- endif -%}
      {%- if s.body != blank -%}<div class="pb-story__text pb-mt-1">{{ s.body }}</div>{%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="pb-story__pillars">
          {%- for block in section.blocks -%}
            <li {{ block.shopify_attributes }}>
              <span class="pb-story__pillar-t">{{ block.settings.title }}</span>
              {%- if block.settings.text != blank -%}<span class="pb-story__pillar-d">{{ block.settings.text }}</span>{%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if s.btn_label != blank -%}
        <div class="pb-actions pb-mt-2"><a class="pb-btn pb-btn--gold" href="{{ s.btn_link | default: '#' }}">{{ s.btn_label }}</a></div>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
.pb-story__grid{display:grid;grid-template-columns:1fr;gap:clamp(2rem,5vw,4rem);align-items:center;}
.pb-story__media{aspect-ratio:4/5;border-radius:var(--pb-radius-lg);}
.pb-story__ph{position:absolute;inset:0;width:100%;height:100%;}
.pb-story__text{font-size:var(--pb-body);line-height:1.75;color:var(--pb-muted);max-width:54ch;}
.pb-story__text p{margin:0 0 1rem;}
.pb-story__pillars{list-style:none;margin:2rem 0 0;padding:0;display:grid;gap:1.1rem;border-top:1px solid var(--pb-line);padding-top:1.6rem;}
.pb-story__pillars li{display:flex;flex-direction:column;gap:.2rem;}
.pb-story__pillar-t{font-family:var(--pb-font-heading);font-size:1.05rem;font-weight:600;}
.pb-story__pillar-d{font-size:.92rem;color:var(--pb-muted);line-height:1.5;}
@media(min-width:750px){
  .pb-story__grid{grid-template-columns:1fr 1fr;}
  .pb-story.is-reverse .pb-story__media{order:2;}
  .pb-story__pillars{grid-template-columns:1fr 1fr;}
}
{% endstylesheet %}

{% schema %}
{
  "name": "PB · Brand Story",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "checkbox", "id": "reverse", "label": "Image on right", "default": false },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "OUR STORY" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "More than clothing." },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Punjab Bolda is a movement stitched into fabric — heritage reimagined for a generation that wears its roots on its sleeve. From the fields of Punjab to the streets of the diaspora, every piece carries identity, culture and an unshakeable sense of pride.</p>" },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Read our story" },
    { "type": "url", "id": "btn_link", "label": "Button link" },
    { "type": "color", "id": "bg", "label": "Background", "default": "#F5F1E8" }
  ],
  "blocks": [
    { "type": "pillar", "name": "Pillar", "settings": [
      { "type": "text", "id": "title", "label": "Title", "default": "Identity" },
      { "type": "text", "id": "text", "label": "Text", "default": "Wear who you are." }
    ] }
  ],
  "max_blocks": 4,
  "presets": [ { "name": "PB · Brand Story", "blocks": [
    { "type": "pillar", "settings": { "title": "Heritage", "text": "Rooted in Punjab." } },
    { "type": "pillar", "settings": { "title": "Confidence", "text": "Designed to be seen." } },
    { "type": "pillar", "settings": { "title": "Culture", "text": "Stories in every stitch." } },
    { "type": "pillar", "settings": { "title": "Pride", "text": "For the global generation." } }
  ] } ]
}
{% endschema %}
