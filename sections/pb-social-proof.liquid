{%- comment -%} Punjab Bolda · Social Proof — testimonials + UGC gallery {%- endcomment -%}
{%- liquid assign s = section.settings -%}
<section class="pb pb-section pb-sp" style="background:{{ s.bg }};">
  <div class="pb-wrap">
    <header class="pb-sp__head pb-reveal">
      {%- if s.eyebrow != blank -%}<p class="pb-eyebrow pb-eyebrow--center">{{ s.eyebrow }}</p>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="pb-h2 pb-center">{{ s.heading }}</h2>{%- endif -%}
    </header>

    {%- assign reviews = section.blocks | where: 'type', 'testimonial' -%}
    {%- if reviews.size > 0 -%}
      <div class="pb-sp__reviews">
        {%- for block in reviews -%}
          <figure class="pb-sp__review pb-reveal" {{ block.shopify_attributes }} data-pb-stagger>
            <div class="pb-sp__stars" aria-label="5 out of 5 stars">
              {%- for i in (1..5) -%}{% render 'pb-icon', icon: 'star' %}{%- endfor -%}
            </div>
            <blockquote class="pb-sp__quote">{{ block.settings.quote }}</blockquote>
            <figcaption class="pb-sp__by">
              {%- if block.settings.avatar != blank -%}<img src="{{ block.settings.avatar | image_url: width: 80 }}" width="40" height="40" alt="" loading="lazy">{%- endif -%}
              <span><strong>{{ block.settings.name }}</strong>{% if block.settings.location != blank %}<em>{{ block.settings.location }}</em>{% endif %}</span>
            </figcaption>
          </figure>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- assign shots = section.blocks | where: 'type', 'photo' -%}
    {%- if shots.size > 0 -%}
      <div class="pb-sp__ugc">
        {%- if s.ugc_label != blank -%}<p class="pb-sp__ugc-label pb-reveal">{{ s.ugc_label }}</p>{%- endif -%}
        <div class="pb-sp__gallery">
          {%- for block in shots -%}
            {%- assign img = block.settings.image -%}
            <a class="pb-sp__shot pb-media pb-zoom pb-reveal" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }} data-pb-stagger>
              {%- if img != blank -%}
                <img src="{{ img | image_url: width: 400 }}" width="{{ img.width }}" height="{{ img.height }}" alt="{{ img.alt | escape | default: 'Punjab Bolda customer' }}" loading="lazy">
              {%- else -%}{{ 'image' | placeholder_svg_tag: 'pb-sp__ph' }}{%- endif -%}
            </a>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.pb-sp__head{margin-bottom:clamp(2rem,5vw,3.5rem);}
.pb-sp__reviews{display:grid;grid-template-columns:1fr;gap:1.2rem;}
.pb-sp__review{background:var(--pb-card);border:1px solid var(--pb-line);border-radius:var(--pb-radius-lg);padding:clamp(1.5rem,3vw,2.2rem);box-shadow:var(--pb-shadow-sm);}
.pb-sp__stars{display:flex;gap:3px;color:var(--pb-gold);margin-bottom:1rem;}
.pb-sp__quote{font-family:var(--pb-font-heading);font-size:clamp(1.1rem,2vw,1.35rem);line-height:1.4;font-weight:500;margin:0 0 1.3rem;}
.pb-sp__by{display:flex;align-items:center;gap:.75rem;}
.pb-sp__by img{border-radius:50%;object-fit:cover;}
.pb-sp__by span{display:flex;flex-direction:column;line-height:1.3;}
.pb-sp__by strong{font-size:.92rem;}
.pb-sp__by em{font-style:normal;font-size:.78rem;color:var(--pb-muted);}
.pb-sp__ugc{margin-top:clamp(2.5rem,5vw,4rem);}
.pb-sp__ugc-label{text-align:center;font-size:.72rem;letter-spacing:.2em;text-transform:uppercase;color:var(--pb-muted);margin:0 0 1.2rem;}
.pb-sp__gallery{display:grid;grid-template-columns:repeat(2,1fr);gap:.6rem;}
.pb-sp__shot{aspect-ratio:1;border-radius:var(--pb-radius);display:block;}
.pb-sp__shot img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}
.pb-sp__ph{position:absolute;inset:0;width:100%;height:100%;}
@media(min-width:750px){
  .pb-sp__reviews{grid-template-columns:repeat(3,1fr);}
  .pb-sp__gallery{grid-template-columns:repeat(6,1fr);gap:.8rem;}
}
{% endstylesheet %}

{% schema %}
{
  "name": "PB · Social Proof",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "THE COMMUNITY" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Worn worldwide." },
    { "type": "text", "id": "ugc_label", "label": "Gallery label", "default": "TAG @PUNJABBOLDA TO BE FEATURED" },
    { "type": "color", "id": "bg", "label": "Background", "default": "#F5F1E8" }
  ],
  "blocks": [
    { "type": "testimonial", "name": "Testimonial", "settings": [
      { "type": "textarea", "id": "quote", "label": "Quote", "default": "The quality is unreal and it finally feels like fashion that represents me. Proud to rep Punjab." },
      { "type": "image_picker", "id": "avatar", "label": "Avatar" },
      { "type": "text", "id": "name", "label": "Name", "default": "Gurpreet S." },
      { "type": "text", "id": "location", "label": "Location", "default": "Toronto, CA" }
    ] },
    { "type": "photo", "name": "Customer photo", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "url", "id": "link", "label": "Link (optional)" }
    ] }
  ],
  "max_blocks": 16,
  "presets": [ { "name": "PB · Social Proof", "blocks": [
    { "type": "testimonial" }, { "type": "testimonial" }, { "type": "testimonial" },
    { "type": "photo" }, { "type": "photo" }, { "type": "photo" }, { "type": "photo" }, { "type": "photo" }, { "type": "photo" }
  ] } ]
}
{% endschema %}
