{%- comment -%}
  Punjab Bolda · Recently Viewed
  Tracks product handles in localStorage and renders cards via Shopify's native
  Product JSON (?view=…) — no app, no customer data stored server-side.
{%- endcomment -%}
{%- liquid assign s = section.settings -%}
<section class="pb pb-section pb-rv" style="background:{{ s.bg }};" data-pb-recent
  data-current="{% if product %}{{ product.handle }}{% endif %}" data-limit="{{ s.limit }}" hidden>
  <div class="pb-wrap">
    <header class="pb-rv__head pb-reveal">
      {%- if s.eyebrow != blank -%}<p class="pb-eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="pb-h2">{{ s.heading }}</h2>{%- endif -%}
    </header>
    <div class="pb-rv__grid" data-pb-recent-grid></div>
  </div>
</section>

<script>
(function(){
  var KEY='pb_recently_viewed';
  var sec=document.querySelector('[data-pb-recent]');
  if(!sec)return;
  var current=sec.dataset.current,limit=parseInt(sec.dataset.limit)||4;

  /* Record current product */
  var list=[];try{list=JSON.parse(localStorage.getItem(KEY)||'[]');}catch(e){}
  if(current){list=list.filter(function(h){return h!==current;});list.unshift(current);list=list.slice(0,12);localStorage.setItem(KEY,JSON.stringify(list));}

  /* Render others */
  var toShow=list.filter(function(h){return h!==current;}).slice(0,limit);
  if(!toShow.length)return;
  var grid=sec.querySelector('[data-pb-recent-grid]');
  Promise.all(toShow.map(function(h){
    return fetch('/products/'+h+'.js').then(function(r){return r.ok?r.json():null;}).catch(function(){return null;});
  })).then(function(items){
    var html='';
    items.filter(Boolean).forEach(function(p){
      var img=p.featured_image?('<img src="'+p.featured_image+'&width=600" alt="'+(p.title||'').replace(/"/g,'')+'" loading="lazy" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">'):'';
      var price=(p.price/100).toLocaleString(undefined,{style:'currency',currency:'{{ cart.currency.iso_code }}'});
      html+='<article class="pb-card"><a class="pb-card__media pb-media pb-zoom" href="'+p.url+'" style="aspect-ratio:4/5;">'+img+'</a>'+
            '<div class="pb-card__body"><h3 class="pb-card__title"><a href="'+p.url+'">'+p.title+'</a></h3>'+
            '<p class="pb-card__price">'+price+'</p></div></article>';
    });
    if(html){grid.innerHTML=html;sec.hidden=false;}
  });
})();
</script>

{% stylesheet %}
.pb-rv__head{margin-bottom:clamp(1.6rem,4vw,2.6rem);}
.pb-rv__grid{display:grid;grid-template-columns:repeat(2,1fr);gap:clamp(1.2rem,2.5vw,2rem) clamp(.8rem,2vw,1.4rem);}
@media(min-width:750px){.pb-rv__grid{grid-template-columns:repeat(4,1fr);}}
{% endstylesheet %}

{% schema %}
{
  "name": "PB · Recently Viewed",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "PICK UP WHERE YOU LEFT OFF" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Recently viewed" },
    { "type": "range", "id": "limit", "min": 2, "max": 8, "step": 1, "label": "Products", "default": 4 },
    { "type": "color", "id": "bg", "label": "Background", "default": "#EEE1D3" }
  ],
  "presets": [ { "name": "PB · Recently Viewed" } ]
}
{% endschema %}
