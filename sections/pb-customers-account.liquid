{%- comment -%} Punjab Bolda · Account Dashboard — native customer object {%- endcomment -%}
{%- assign s = section.settings -%}
{%- paginate customer.orders by 20 -%}
<section class="pb pb-account" style="background:{{ s.bg }};">
  <div class="pb-wrap">
    <header class="pb-account__head">
      <div>
        {%- if s.eyebrow != blank -%}<p class="pb-eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
        <h1 class="pb-h2">{{ s.heading | default: 'My account' }}</h1>
        <p class="pb-lead pb-mt-1">{{ s.greeting | default: 'Welcome back' }}, {{ customer.first_name | default: customer.email }}.</p>
      </div>
      <a class="pb-account__logout" href="{{ routes.account_logout_url }}">Sign out</a>
    </header>

    <div class="pb-account__grid">
      <div class="pb-account__main">
        <h2 class="pb-panel__title">Order history</h2>
        {%- if customer.orders.size > 0 -%}
          <div class="pb-account__tablewrap">
            <table class="pb-table pb-account__table">
              <thead><tr><th>Order</th><th>Date</th><th>Payment</th><th>Fulfillment</th><th>Total</th></tr></thead>
              <tbody>
                {%- for order in customer.orders -%}
                  <tr>
                    <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
                    <td>{{ order.created_at | date: '%b %d, %Y' }}</td>
                    <td><span class="pb-badge pb-badge--{{ order.financial_status }}">{{ order.financial_status_label }}</span></td>
                    <td><span class="pb-badge pb-badge--{{ order.fulfillment_status }}">{{ order.fulfillment_status_label }}</span></td>
                    <td>{{ order.total_net_amount | money }}</td>
                  </tr>
                {%- endfor -%}
              </tbody>
            </table>

            <div class="pb-orders-cards pb-account__cards">
              {%- for order in customer.orders -%}
                <a class="pb-aside-card" href="{{ order.customer_url }}" style="display:block;text-decoration:none;color:inherit;">
                  <div style="display:flex;justify-content:space-between;"><strong>{{ order.name }}</strong><span>{{ order.total_net_amount | money }}</span></div>
                  <div style="color:var(--pb-muted);font-size:.84rem;margin:.3rem 0;">{{ order.created_at | date: '%b %d, %Y' }}</div>
                  <span class="pb-badge pb-badge--{{ order.financial_status }}">{{ order.financial_status_label }}</span>
                  <span class="pb-badge pb-badge--{{ order.fulfillment_status }}">{{ order.fulfillment_status_label }}</span>
                </a>
              {%- endfor -%}
            </div>
          </div>

          {%- if paginate.pages > 1 -%}
            <nav class="pb-pagination" aria-label="Orders pagination">
              {%- if paginate.previous -%}<a class="pb-pagination__arrow" href="{{ paginate.previous.url }}">{% render 'pb-icon', icon: 'arrow-left' %}</a>{%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}<a class="pb-pagination__num" href="{{ part.url }}">{{ part.title }}</a>
                {%- elsif part.title == paginate.current_page -%}<span class="pb-pagination__num is-current">{{ part.title }}</span>
                {%- else -%}<span class="pb-pagination__gap">{{ part.title }}</span>{%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}<a class="pb-pagination__arrow" href="{{ paginate.next.url }}">{% render 'pb-icon', icon: 'arrow-right' %}</a>{%- endif -%}
            </nav>
          {%- endif -%}
        {%- else -%}
          <p class="pb-lead">You haven’t placed any orders yet.</p>
          <a class="pb-btn pb-btn--gold pb-mt-1" href="{{ routes.all_products_collection_url }}">Start shopping</a>
        {%- endif -%}
      </div>

      <aside class="pb-account__aside">
        <div class="pb-aside-card">
          <h2 class="pb-panel__title" style="font-size:1.05rem;">Default address</h2>
          {%- if customer.default_address -%}
            <address>{{ customer.default_address | format_address }}</address>
          {%- else -%}
            <p style="color:var(--pb-muted);font-size:.9rem;">No address saved yet.</p>
          {%- endif -%}
          <a class="pb-auth__link" style="display:inline-block;margin-top:1rem;" href="{{ routes.account_addresses_url }}">Manage addresses</a>
        </div>
      </aside>
    </div>
 </div>
  {% endpaginate %}
</section>

{% schema %}
{
  "name": "PB · Account",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "YOUR ACCOUNT" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "My account" },
    { "type": "text", "id": "greeting", "label": "Greeting", "default": "Welcome back" },
    { "type": "color", "id": "bg", "label": "Background", "default": "#F5F1E8" }
  ],
  "presets": [ { "name": "PB · Account" } ]
}
{% endschema %}
