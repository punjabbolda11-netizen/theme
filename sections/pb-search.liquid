{%- comment -%}
  Punjab Bolda · Search Results
  Native Shopify search (search.performed / search.results) with optional native
  search filters (search.filters) and pagination. No app.
{%- endcomment -%}
{%- assign s = section.settings -%}
{%- paginate search.results by s.per_page -%}
<section class="pb pb-section pb-search-page" style="background:{{ s.bg }};">
  <div class="pb-wrap">

    <header class="pb-searchp__head pb-reveal">
      {%- if s.eyebrow != blank -%}<p class="pb-eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
      <h1 class="pb-h2">
        {%- if search.performed -%}{{ s.results_label | default: 'Search' }}{%- else -%}{{ s.heading | default: 'Search' }}{%- endif -%}
      </h1>

      <form action="{{ routes.search_url }}" method="get" role="search" class="pb-searchp__form">
        <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search streetwear, caps, collections…" aria-label="Search" autocomplete="off" autofocus>
        <input type="hidden" name="options[prefix]" value="last">
        <button type="submit" class="pb-searchp__submit" aria-label="Search">{% render 'pb-icon', icon: 'search' %}</button>
      </form>

      {%- if search.performed -%}
        <p class="pb-searchp__count">{{ search.results_count }} {{ search.results_count | pluralize: 'result', 'results' }}{% if search.terms != blank %} for “{{ search.terms }}”{% endif %}</p>
      {%- endif -%}
    </header>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}

        {%- comment -%} Optional native search filters {%- endcomment -%}
        {%- if s.show_filters and search.filters != empty -%}
          <form class="pb-searchp__filters" data-pb-search-filters>
            <input type="hidden" name="q" value="{{ search.terms | escape }}">
            <input type="hidden" name="options[prefix]" value="last">
            {%- for filter in search.filters -%}
              {%- if filter.type == 'list' -%}
                <details class="pb-facet pb-facet--inline">
                  <summary>{{ filter.label }} {% render 'pb-icon', icon: 'chevron' %}</summary>
                  <ul class="pb-facet__list">
                    {%- for v in filter.values -%}
                      <li><label class="pb-facet__opt"><input type="checkbox" name="{{ v.param_name }}" value="{{ v.value }}" {% if v.active %}checked{% endif %} data-pb-autosubmit><span class="pb-facet__box">{% render 'pb-icon', icon: 'check' %}</span><span class="pb-facet__name">{{ v.label }}</span><span class="pb-facet__count">{{ v.count }}</span></label></li>
                    {%- endfor -%}
                  </ul>
                </details>
              {%- endif -%}
            {%- endfor -%}
          </form>
        {%- endif -%}

        <div class="pb-searchp__grid">
          {%- for item in search.results -%}
            {%- case item.object_type -%}
              {%- when 'product' -%}
                {% render 'pb-product-card', product: item, quick_add: s.quick_add %}
              {%- when 'article' -%}
                <article class="pb-card pb-reveal" data-pb-stagger>
                  <a class="pb-card__media pb-media pb-zoom" href="{{ item.url }}" style="aspect-ratio:3/2;">
                    {%- if item.image -%}<img src="{{ item.image | image_url: width: 600 }}" alt="{{ item.title | escape }}" loading="lazy" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">{%- else -%}{{ 'image' | placeholder_svg_tag: 'pb-card__ph' }}{%- endif -%}
                  </a>
                  <div class="pb-card__body"><p class="pb-card__type">Journal</p><h3 class="pb-card__title"><a href="{{ item.url }}">{{ item.title }}</a></h3></div>
                </article>
              {%- when 'page' -%}
                <article class="pb-card pb-reveal" data-pb-stagger>
                  <a class="pb-searchp__page" href="{{ item.url }}">
                    <span class="pb-card__type">Page</span>
                    <h3 class="pb-card__title">{{ item.title }}</h3>
                    <p class="pb-searchp__pageexc">{{ item.content | strip_html | truncatewords: 18 }}</p>
                  </a>
                </article>
            {%- endcase -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="pb-pagination" aria-label="Pagination">
            {%- if paginate.previous -%}<a class="pb-pagination__arrow" href="{{ paginate.previous.url }}" aria-label="Previous">{% render 'pb-icon', icon: 'arrow-left' %}</a>{%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}<a class="pb-pagination__num" href="{{ part.url }}">{{ part.title }}</a>
              {%- elsif part.title == paginate.current_page -%}<span class="pb-pagination__num is-current" aria-current="page">{{ part.title }}</span>
              {%- else -%}<span class="pb-pagination__gap">{{ part.title }}</span>{%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}<a class="pb-pagination__arrow" href="{{ paginate.next.url }}" aria-label="Next">{% render 'pb-icon', icon: 'arrow-right' %}</a>{%- endif -%}
          </nav>
        {%- endif -%}

      {%- else -%}
        <div class="pb-searchp__empty">
          <p class="pb-h3">No results for “{{ search.terms }}”.</p>
          <p class="pb-lead">Try a different term, or explore the collections below.</p>
          {%- if s.empty_link_1 != blank or s.empty_link_2 != blank -%}
            <div class="pb-actions pb-actions--center pb-mt-2">
              {%- if s.empty_link_1 != blank -%}<a class="pb-btn pb-btn--ghost" href="{{ s.empty_link_1 }}">{{ s.empty_label_1 | default: 'Shop streetwear' }}</a>{%- endif -%}
              {%- if s.empty_link_2 != blank -%}<a class="pb-btn pb-btn--ghost" href="{{ s.empty_link_2 }}">{{ s.empty_label_2 | default: 'Shop caps' }}</a>{%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
  {% endpaginate %}
</section>

<script>
(function(){
  var sec=document.currentScript.previousElementSibling;
  var ff=sec.querySelector('[data-pb-search-filters]');
  if(ff){ff.addEventListener('change',function(e){
    if(e.target.matches('[data-pb-autosubmit]')){
      var fd=new FormData(ff),p=new URLSearchParams();
      fd.forEach(function(v,k){if(v!=='')p.append(k,v);});
      window.location.href='{{ routes.search_url }}?'+p.toString();
    }
  });}
})();
</script>

{% stylesheet %}
.pb-searchp__head{max-width:680px;margin-bottom:clamp(2rem,4vw,3rem);}
.pb-searchp__form{display:flex;align-items:center;gap:.6rem;border-bottom:2px solid var(--pb-text);padding-bottom:.7rem;margin-top:1.2rem;}
.pb-searchp__form input[type=search]{flex:1;border:0;background:transparent;font-family:var(--pb-font-heading);font-size:clamp(1.2rem,3vw,1.7rem);color:var(--pb-text);outline:none;min-width:0;}
.pb-searchp__submit{background:none;border:0;cursor:pointer;color:var(--pb-text);padding:.3rem;}
.pb-searchp__count{margin-top:1rem;font-size:.78rem;letter-spacing:.08em;text-transform:uppercase;color:var(--pb-muted);}
.pb-searchp__filters{display:flex;flex-wrap:wrap;gap:.6rem;margin-bottom:1.6rem;}
.pb-facet--inline{border:1px solid var(--pb-line-strong);border-radius:var(--pb-radius);padding:0 .9rem;position:relative;}
.pb-facet--inline summary{border:0;padding:.7rem 0;font-size:.78rem;letter-spacing:.08em;text-transform:uppercase;}
.pb-facet--inline .pb-facet__list{position:absolute;z-index:5;left:0;top:100%;background:var(--pb-card);box-shadow:var(--pb-shadow);border-radius:var(--pb-radius);padding:.8rem;min-width:220px;max-height:300px;}
.pb-searchp__grid{display:grid;grid-template-columns:repeat(2,1fr);gap:clamp(1.2rem,2.5vw,2rem) clamp(.8rem,2vw,1.4rem);}
.pb-searchp__page{display:block;padding:1.2rem;background:var(--pb-card);border:1px solid var(--pb-line);border-radius:var(--pb-radius);text-decoration:none;color:var(--pb-text);height:100%;}
.pb-searchp__pageexc{font-size:.88rem;color:var(--pb-muted);line-height:1.6;margin:.5rem 0 0;}
.pb-searchp__empty{text-align:center;padding:3rem 1rem;}
.pb-searchp__empty .pb-lead{margin-inline:auto;}
@media(min-width:750px){.pb-searchp__grid{grid-template-columns:repeat(4,1fr);}}
{% endstylesheet %}

{% schema %}
{
  "name": "PB · Search",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FIND YOUR FIT" },
    { "type": "text", "id": "heading", "label": "Heading (no search yet)", "default": "Search" },
    { "type": "text", "id": "results_label", "label": "Results heading", "default": "Search results" },
    { "type": "range", "id": "per_page", "min": 8, "max": 48, "step": 4, "label": "Results per page", "default": 24 },
    { "type": "checkbox", "id": "show_filters", "label": "Show search filters (native)", "default": true },
    { "type": "checkbox", "id": "quick_add", "label": "Enable quick add", "default": true },
    { "type": "header", "content": "Empty state" },
    { "type": "text", "id": "empty_label_1", "label": "Button 1 label", "default": "Shop streetwear" },
    { "type": "url", "id": "empty_link_1", "label": "Button 1 link" },
    { "type": "text", "id": "empty_label_2", "label": "Button 2 label", "default": "Shop caps" },
    { "type": "url", "id": "empty_link_2", "label": "Button 2 link" },
    { "type": "color", "id": "bg", "label": "Background", "default": "#F5F1E8" }
  ],
  "enabled_on": { "templates": ["search"] },
  "presets": [ { "name": "PB · Search" } ]
}
{% endschema %}
