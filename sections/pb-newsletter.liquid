{%- comment -%} Punjab Bolda · Newsletter — native Shopify customer form {%- endcomment -%}
{%- liquid assign s = section.settings -%}
<section class="pb pb-section pb-nl" style="background:{{ s.bg }};color:{{ s.fg }};{% if s.image != blank %}--pb-nl-img:url('{{ s.image | image_url: width: 1800 }}');{% endif %}">
  {%- if s.image != blank -%}<span class="pb-nl__bg" aria-hidden="true"></span><span class="pb-nl__scrim" aria-hidden="true"></span>{%- endif -%}
  <div class="pb-wrap pb-nl__inner pb-reveal">
    {%- if s.eyebrow != blank -%}<p class="pb-eyebrow pb-eyebrow--center" style="color:var(--pb-gold)">{{ s.eyebrow }}</p>{%- endif -%}
    {%- if s.heading != blank -%}<h2 class="pb-h2 pb-center">{{ s.heading }}</h2>{%- endif -%}
    {%- if s.subheading != blank -%}<p class="pb-nl__sub">{{ s.subheading }}</p>{%- endif -%}

    {%- form 'customer', class: 'pb-nl__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      {%- if form.posted_successfully? -%}
        <p class="pb-nl__success" role="status">{% render 'pb-icon', icon: 'check' %} {{ s.success | default: 'You’re in. Welcome to the movement.' }}</p>
      {%- else -%}
        <label class="pb-nl__label" for="pb-nl-email">Email address</label>
        <div class="pb-nl__row">
          <input id="pb-nl-email" type="email" name="contact[email]" required autocomplete="email"
                 placeholder="{{ s.placeholder | default: 'Enter your email' }}" class="pb-nl__input"
                 {% if form.errors %}aria-invalid="true"{% endif %}>
          <button type="submit" class="pb-btn pb-btn--gold pb-nl__btn">{{ s.btn_label | default: 'Join' }}</button>
        </div>
        {%- if form.errors -%}<p class="pb-nl__error" role="alert">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>{%- endif -%}
      {%- endif -%}
    {%- endform -%}

    {%- if s.note != blank -%}<p class="pb-nl__note">{{ s.note }}</p>{%- endif -%}
  </div>
</section>

{% stylesheet %}
.pb-nl{position:relative;overflow:hidden;isolation:isolate;}
.pb-nl__bg{position:absolute;inset:0;z-index:-2;background-image:var(--pb-nl-img);background-size:cover;background-position:center;}
.pb-nl__scrim{position:absolute;inset:0;z-index:-1;background:rgba(17,17,17,.62);}
.pb-nl__inner{max-width:620px;margin-inline:auto;text-align:center;}
.pb-nl__sub{margin:1rem auto 0;font-size:var(--pb-body);line-height:1.6;opacity:.82;max-width:46ch;}
.pb-nl__form{margin-top:2rem;}
.pb-nl__label{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);}
.pb-nl__row{display:flex;flex-direction:column;gap:.6rem;}
.pb-nl__input{flex:1;min-height:54px;padding:0 1.2rem;border:1px solid var(--pb-line-strong);background:#fff;color:var(--pb-text);border-radius:var(--pb-radius);font-size:1rem;font-family:var(--pb-font-body);}
.pb-nl__input::placeholder{color:var(--pb-muted);}
.pb-nl__btn{white-space:nowrap;}
.pb-nl__note{margin-top:1rem;font-size:.74rem;opacity:.7;}
.pb-nl__success{display:inline-flex;align-items:center;gap:.6rem;font-size:1.05rem;font-weight:600;color:var(--pb-gold);}
.pb-nl__error{margin-top:.7rem;font-size:.82rem;color:#e8b4b4;}
@media(min-width:600px){.pb-nl__row{flex-direction:row;}.pb-nl__btn{flex:0 0 auto;}}
{% endstylesheet %}

{% schema %}
{
  "name": "PB · Newsletter",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "STAY ROOTED" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join the movement." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Get early access to new drops, exclusive releases and stories from the culture." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Enter your email" },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Join" },
    { "type": "text", "id": "success", "label": "Success message", "default": "You’re in. Welcome to the movement." },
    { "type": "text", "id": "note", "label": "Fine print", "default": "No spam. Unsubscribe anytime." },
    { "type": "image_picker", "id": "image", "label": "Background image (optional)" },
    { "type": "color", "id": "bg", "label": "Background", "default": "#111111" },
    { "type": "color", "id": "fg", "label": "Text", "default": "#FFFFFF" }
  ],
  "presets": [ { "name": "PB · Newsletter" } ]
}
{% endschema %}
