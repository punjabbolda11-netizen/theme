{%- comment -%} Punjab Bolda · FAQ — accessible accordion + FAQPage schema {%- endcomment -%}
{%- liquid assign s = section.settings -%}
<section class="pb pb-section pb-faq" style="background:{{ s.bg }};">
  <div class="pb-wrap pb-faq__grid">
    <header class="pb-faq__head pb-reveal">
      {%- if s.eyebrow != blank -%}<p class="pb-eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="pb-h2">{{ s.heading }}</h2>{%- endif -%}
      {%- if s.intro != blank -%}<p class="pb-lead pb-mt-1">{{ s.intro }}</p>{%- endif -%}
    </header>

    <div class="pb-faq__list">
      {%- for block in section.blocks -%}
        <details class="pb-faq__item pb-reveal" {{ block.shopify_attributes }} {% if forloop.first and s.open_first %}open{% endif %}>
          <summary class="pb-faq__q">
            <span>{{ block.settings.question }}</span>
            <span class="pb-faq__icon" aria-hidden="true"></span>
          </summary>
          <div class="pb-faq__a">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- if section.blocks.size > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in section.blocks -%}
    {
      "@type": "Question",
      "name": {{ block.settings.question | json }},
      "acceptedAnswer": { "@type": "Answer", "text": {{ block.settings.answer | strip_html | json }} }
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

{% stylesheet %}
.pb-faq__grid{display:grid;grid-template-columns:1fr;gap:clamp(2rem,4vw,3rem);}
.pb-faq__head{max-width:40ch;}
.pb-faq__item{border-bottom:1px solid var(--pb-line);}
.pb-faq__item:first-child{border-top:1px solid var(--pb-line);}
.pb-faq__q{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:1.3rem 0;cursor:pointer;list-style:none;font-family:var(--pb-font-heading);font-size:clamp(1.05rem,2vw,1.25rem);font-weight:600;}
.pb-faq__q::-webkit-details-marker{display:none;}
.pb-faq__icon{position:relative;width:18px;height:18px;flex:0 0 auto;}
.pb-faq__icon::before,.pb-faq__icon::after{content:"";position:absolute;background:var(--pb-gold);transition:transform .35s var(--pb-ease);}
.pb-faq__icon::before{top:8px;left:0;width:18px;height:2px;}
.pb-faq__icon::after{top:0;left:8px;width:2px;height:18px;}
.pb-faq__item[open] .pb-faq__icon::after{transform:scaleY(0);}
.pb-faq__a{padding:0 0 1.4rem;font-size:var(--pb-body);line-height:1.7;color:var(--pb-muted);max-width:68ch;}
.pb-faq__a p{margin:0 0 .8rem;}
@media(min-width:850px){.pb-faq__grid{grid-template-columns:1fr 1.6fr;}}
{% endstylesheet %}

{% schema %}
{
  "name": "PB · FAQ",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "GOOD TO KNOW" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked." },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Everything you need before you cop." },
    { "type": "checkbox", "id": "open_first", "label": "Open first item", "default": true },
    { "type": "color", "id": "bg", "label": "Background", "default": "#F5F1E8" }
  ],
  "blocks": [
    { "type": "qa", "name": "Question", "settings": [
      { "type": "text", "id": "question", "label": "Question", "default": "How is the sizing?" },
      { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Our streetwear runs true to size with a relaxed fit. For an oversized look, size up. See each product's size guide for exact measurements.</p>" }
    ] }
  ],
  "max_blocks": 12,
  "presets": [ { "name": "PB · FAQ", "blocks": [
    { "type": "qa", "settings": { "question": "How is the sizing?", "answer": "<p>Our streetwear runs true to size with a relaxed fit. For an oversized look, size up.</p>" } },
    { "type": "qa", "settings": { "question": "Where do you ship?", "answer": "<p>We ship worldwide — including the USA, Canada, UK and Australia. Free shipping over $120.</p>" } },
    { "type": "qa", "settings": { "question": "What is your return policy?", "answer": "<p>Unworn items can be returned within 30 days for a full refund or exchange.</p>" } },
    { "type": "qa", "settings": { "question": "Are the designs authentic?", "answer": "<p>Every piece is designed in-house and rooted in genuine Punjabi culture — never mass-produced clichés.</p>" } }
  ] } ]
}
{% endschema %}
