{%- comment -%}
  Punjab Bolda · Related Products
  Uses Shopify's NATIVE Product Recommendations API (/recommendations/products).
  Powered by Shopify's Search & Discovery — no third-party app.
{%- endcomment -%}
{%- liquid assign s = section.settings -%}
<section class="pb pb-section pb-rel"
  style="background:{{ s.bg }};"
  data-pb-related
  data-url="{{ routes.product_recommendations_url }}"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-limit="{{ s.limit }}"
  data-intent="related">
  <div class="pb-wrap">
    {%- if recommendations.performed -%}
      {%- if recommendations.products_count > 0 -%}
        <header class="pb-rel__head pb-reveal">
          {%- if s.eyebrow != blank -%}<p class="pb-eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
          {%- if s.heading != blank -%}<h2 class="pb-h2">{{ s.heading }}</h2>{%- endif -%}
        </header>
        <div class="pb-rel__grid">
          {%- for product in recommendations.products limit: s.limit -%}
            {% render 'pb-product-card', product: product, quick_add: s.quick_add %}
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- else -%}
      {%- comment -%} Placeholder shown before JS swaps in recommendations {%- endcomment -%}
      <header class="pb-rel__head">
        {%- if s.eyebrow != blank -%}<p class="pb-eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="pb-h2">{{ s.heading }}</h2>{%- endif -%}
      </header>
      <div class="pb-rel__grid" aria-hidden="true">
        {%- for i in (1..s.limit) -%}
          <div class="pb-card"><div class="pb-card__media pb-media" style="aspect-ratio:4/5;"></div><div class="pb-card__body"><div style="height:14px;width:70%;background:var(--pb-line);border-radius:3px;margin:.6rem 0;"></div><div style="height:12px;width:40%;background:var(--pb-line);border-radius:3px;"></div></div></div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{%- unless recommendations.performed -%}
<script>
(function(){
  var sec=document.querySelector('[data-pb-related]');
  if(!sec)return;
  var url=sec.dataset.url+'?section_id='+sec.dataset.sectionId+'&product_id='+sec.dataset.productId+'&limit='+sec.dataset.limit+'&intent='+sec.dataset.intent;
  fetch(url).then(function(r){return r.text();}).then(function(html){
    var doc=new DOMParser().parseFromString(html,'text/html');
    var fresh=doc.querySelector('[data-pb-related] .pb-wrap');
    if(fresh){sec.querySelector('.pb-wrap').innerHTML=fresh.innerHTML;document.dispatchEvent(new CustomEvent('shopify:section:load'));}
    else{sec.style.display='none';}
  }).catch(function(){sec.style.display='none';});
})();
</script>
{%- endunless -%}

{% stylesheet %}
.pb-rel__head{margin-bottom:clamp(1.6rem,4vw,2.6rem);}
.pb-rel__grid{display:grid;grid-template-columns:repeat(2,1fr);gap:clamp(1.2rem,2.5vw,2rem) clamp(.8rem,2vw,1.4rem);}
@media(min-width:750px){.pb-rel__grid{grid-template-columns:repeat(4,1fr);}}
{% endstylesheet %}

{% schema %}
{
  "name": "PB · Related Products",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "COMPLETE THE FIT" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "You may also like" },
    { "type": "range", "id": "limit", "min": 2, "max": 8, "step": 1, "label": "Products", "default": 4 },
    { "type": "checkbox", "id": "quick_add", "label": "Enable quick add", "default": true },
    { "type": "color", "id": "bg", "label": "Background", "default": "#F5F1E8" }
  ],
  "enabled_on": { "templates": ["product"] },
  "presets": [ { "name": "PB · Related Products" } ]
}
{% endschema %}
