{%- comment -%} Punjab Bolda · Breadcrumbs (visual; JSON-LD handled by pb-seo-schema) {%- endcomment -%}
<nav class="pb-crumbs" aria-label="Breadcrumb">
  <ol>
    <li><a href="{{ routes.root_url }}">Home</a></li>
    {%- if template contains 'collection' and collection != blank -%}
      <li aria-current="page"><span>{{ collection.title }}</span></li>
    {%- elsif template contains 'product' and product != blank -%}
      {%- if collection != blank -%}<li><a href="{{ collection.url }}">{{ collection.title }}</a></li>{%- endif -%}
      <li aria-current="page"><span>{{ product.title }}</span></li>
    {%- elsif template contains 'article' -%}
      <li><a href="{{ blog.url }}">{{ blog.title }}</a></li>
      <li aria-current="page"><span>{{ article.title }}</span></li>
    {%- elsif template contains 'blog' -%}
      <li aria-current="page"><span>{{ blog.title }}</span></li>
    {%- elsif template contains 'page' -%}
      <li aria-current="page"><span>{{ page.title }}</span></li>
    {%- endif -%}
  </ol>
</nav>

{% stylesheet %}
.pb-crumbs ol{list-style:none;display:flex;flex-wrap:wrap;align-items:center;gap:.5rem;margin:0;padding:0;font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;opacity:.85;}
.pb-crumbs li{display:flex;align-items:center;gap:.5rem;}
.pb-crumbs li:not(:last-child)::after{content:"/";opacity:.5;}
.pb-crumbs a{color:inherit;text-decoration:none;opacity:.7;transition:opacity .25s;}
.pb-crumbs a:hover{opacity:1;}
.pb-crumbs [aria-current] span{font-weight:600;}
{% endstylesheet %}
